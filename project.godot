; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="OpenClaw Pixel Office"
config/description="A pixel-art 2D game that visualizes your OpenClaw agents working in a virtual office."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/icon.png"

[autoload]

TaskBoard="*res://scripts/systems/task_board.gd"
TimeSystem="*res://scripts/systems/time_system.gd"
SyncManager="*res://scripts/systems/sync_manager.gd"
GameSettings="*res://scripts/systems/game_settings.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://.godot/autoload/TaskBoard.gd", "res://.godot/autoload/TimeSystem.gd", "res://.godot/autoload/SyncManager.gd")

[gui]

theme/custom="res://assets/theme/theme.tres"

